# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# App Configuration
NEXT_PUBLIC_APP_NAME=PT Semen Nusantara
NEXT_PUBLIC_APP_VERSION=1.0.0

# Environment
NODE_ENV=development

# Frontend
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=your_recaptcha_site_key
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_IMAGE_CDN=local
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Server / API
RECAPTCHA_SECRET=your_recaptcha_secret
SUPABASE_URL=https://xyzcompany.supabase.co
SUPABASE_SERVICE_KEY=your_supabase_service_role_key
REDIS_URL=redis://localhost:6379
ERROR_SERVICE_URL=
ERROR_API_KEY=
CONTACT_NOTIFY_URL=

# OAuth Providers (Configure in Supabase Dashboard)
# Google OAuth: https://console.cloud.google.com/
# Azure OAuth: https://portal.azure.com/
# Add these providers in Supabase > Authentication > Providers
# Redirect URLs: http://localhost:8080, https://yourdomain.com
